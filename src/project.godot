config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Micromachines V3 Clone"
config/description="Top-down arcade racing — Micro Machines V3 PS1 reimagined. 4 players, 2 controllers, 2 buttons each."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

