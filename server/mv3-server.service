[Unit]
Description=MV3 Multiplayer WebSocket Server
After=network.target

[Service]
Type=simple
User=seb
WorkingDirectory=/opt/mv3-server
ExecStart=/opt/mv3-server/venv/bin/python /opt/mv3-server/mv3_server.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
